{
  "name": "mr-ai",
  "displayName": "Super AI Sentinel",
  "description": "Advanced autonomous coding AI - powerful code writing with Code Llama/DeepSeek, interactive chat, less boring!",
  "version": "0.1.0",
  "publisher": "mr-rathore",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mr-ai.askOllama",
        "title": "Ask Super AI Sentinel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-sentinel-container",
          "title": "AI Sentinel",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ai-sentinel-container": [
        {
          "type": "webview",
          "id": "aiSentinelChat",
          "name": "Super AI Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "icon": "media/icon.svg"
}
